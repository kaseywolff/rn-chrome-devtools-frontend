devtools_module("test") {
  sources = [ 
    "TestDevToolView.ts", 
    #"TestDevToolModel.ts" 
  ]

  # add necessary deps here (ONLY what you use)
  deps = [
    "../../core/i18n:bundle",
    "../../core/sdk:bundle",
    "../../models/bindings:bundle",
    "../../models/logs:bundle",
    "../../models/react_native:bundle",
    "../../third_party/react-devtools:bundle",
    "../../ui/legacy:bundle",
